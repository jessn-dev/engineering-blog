---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'] & { readingTime?: string };

const { title, description, pubDate, updatedDate, heroImage, heroImageAttribution, category, categories, readingTime } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "BlogPosting",
			"headline": title,
			"description": description,
			"image": heroImage ? heroImage : undefined,
			"datePublished": pubDate.toISOString(),
			"dateModified": updatedDate ? updatedDate.toISOString() : pubDate.toISOString(),
			"author": {
				"@type": "Person",
				"name": "Jesse Ngolab",
				"url": "https://www.jbn-dev.com/"
			}
		})} />
		<style>
			/* STRIPE DEV ARTICLE AESTHETIC */
			main {
				max-width: 1400px;
				margin: 0 auto;
				padding: 2rem 1.5rem;
				font-family: 'Inter', sans-serif;
			}

			.text-smallcaps {
				font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif, "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol";
				font-size: 11px;
				text-transform: uppercase;
				letter-spacing: 0.04em;
				font-weight: 500;
			}

			/* HERO SECTION */
			.post-hero {
				padding: 2rem 0 4rem 0;
				max-width: 800px;
			}
			.post-title {
				font-size: clamp(2rem, 5vw, 3.5rem);
				font-weight: 700;
				line-height: 1.1;
				letter-spacing: -0.04em;
				margin-bottom: 1.5rem;
				color: #fff;
			}
			.post-summary {
				font-size: 1.15rem;
				line-height: 1.6;
				color: rgba(255, 255, 255, 0.7);
			}

			/* TWO-COLUMN GRID */
			.post-grid {
				display: grid;
				grid-template-columns: 260px 1fr;
				gap: 4rem;
			}
			@media (max-width: 900px) {
				.post-grid {
					grid-template-columns: 1fr;
					gap: 2rem;
				}
			}

			/* SIDEBAR */
			.table-header {
				border-bottom: 1px solid rgba(255,255,255,0.1);
				padding-bottom: 0.75rem;
				margin-bottom: 1.5rem;
				color: rgba(255,255,255,0.6);
			}
			.table-header span {
				color: rgba(255,255,255,0.6);
			}

			.metadata-list {
				display: flex;
				flex-direction: column;
				gap: 1.25rem;
			}
			.metadata-item {
				display: flex;
				flex-direction: column;
				gap: 0.25rem;
			}
			.metadata-item .label {
				color: rgba(255,255,255,0.4);
			}
			.metadata-item .value {
				font-size: 0.85rem;
				font-weight: 500;
				color: #fff;
			}
			
			.tag-group {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem;
				margin-top: 0.25rem;
			}
			.tag {
				display: inline-block;
				background: rgba(255, 255, 255, 0.05);
				padding: 0.2rem 0.5rem;
				border-radius: 4px;
				color: #fff;
				border: 1px solid rgba(255, 255, 255, 0.1);
			}

			/* MAIN CONTENT AREA */
			.article-image-container {
				margin-bottom: 3rem;
			}
			.article-hero-image {
				width: 100%;
				border-radius: 8px;
				border: 1px solid rgba(255,255,255,0.1);
			}
			.attribution {
				margin-top: 0.75rem;
				font-size: 0.75rem;
				color: rgba(255,255,255,0.4);
				text-align: right;
			}

			/* TYPOGRAPHY IN CONTENT */
			.prose {
				color: rgba(255,255,255,0.85);
				font-size: 1.05rem;
				line-height: 1.7;
				max-width: 750px;
			}
			.prose h1, .prose h2, .prose h3, .prose h4 {
				color: #fff;
				font-weight: 600;
				letter-spacing: -0.02em;
				margin-top: 3rem;
				margin-bottom: 1.5rem;
				line-height: 1.3;
			}
			.prose h2 { font-size: 1.75rem; }
			.prose h3 { font-size: 1.4rem; }
			.prose p {
				margin-bottom: 1.5rem;
			}
			.prose a {
				color: #fff;
				text-decoration: underline;
				text-decoration-color: rgba(255,255,255,0.3);
				text-underline-offset: 3px;
				transition: text-decoration-color 0.2s;
			}
			.prose a:hover {
				text-decoration-color: #fff;
			}
			.prose code {
				font-family: 'Space Grotesk', monospace;
				background: rgba(255, 255, 255, 0.08);
				padding: 0.2em 0.4em;
				border-radius: 4px;
				font-size: 0.85em;
			}
			.prose pre {
				background: rgba(0, 0, 0, 0.5) !important;
				border: 1px solid rgba(255,255,255,0.1);
				padding: 1.5rem;
				border-radius: 8px;
				overflow-x: auto;
				margin: 2rem 0;
			}
			.prose blockquote {
				border-left: 2px solid rgba(255,255,255,0.2);
				padding-left: 1.5rem;
				margin-left: 0;
				color: rgba(255,255,255,0.6);
				font-style: italic;
			}
			.prose ul, .prose ol {
				margin-bottom: 1.5rem;
				padding-left: 1.5rem;
			}
			.prose li {
				margin-bottom: 0.5rem;
			}
			.prose table {
				width: 100%;
				border-collapse: collapse;
				margin: 2rem 0;
				font-size: 0.95rem;
				display: block;
				overflow-x: auto;
			}
			.prose th, .prose td {
				border: 1px solid rgba(255, 255, 255, 0.12);
				padding: 0.6rem 0.9rem;
				text-align: left;
				vertical-align: top;
			}
			.prose th {
				background: rgba(255, 255, 255, 0.06);
				color: #fff;
				font-weight: 600;
			}
			.prose tbody tr:nth-child(even) {
				background: rgba(255, 255, 255, 0.02);
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article class="post-layout">
				<header class="post-hero">
					<h1 class="post-title">{title}</h1>
					{description && <p class="post-summary">{description}</p>}
				</header>

				<div class="post-grid">
					<aside class="post-sidebar">
						<div class="table-header">
							<span class="text-smallcaps">/ Metadata</span>
						</div>
						
						<div class="metadata-list">
							<div class="metadata-item">
								<span class="text-smallcaps label">Date Published:</span>
								<span class="value"><FormattedDate date={pubDate} /></span>
							</div>
							
							{updatedDate && (
								<div class="metadata-item">
									<span class="text-smallcaps label">Updated:</span>
									<span class="value"><FormattedDate date={updatedDate} /></span>
								</div>
							)}

							{readingTime && (
								<div class="metadata-item">
									<span class="text-smallcaps label">Reading Time:</span>
									<span class="value">{readingTime}</span>
								</div>
							)}
							
							{(categories && categories.length > 0) ? (
								<div class="metadata-item">
									<span class="text-smallcaps label">Categories:</span>
									<div class="tag-group">
										{categories.map((cat: string) => (
											<span class="text-smallcaps tag">{cat}</span>
										))}
									</div>
								</div>
							) : category ? (
								<div class="metadata-item">
									<span class="text-smallcaps label">Category:</span>
									<div class="tag-group">
										<span class="text-smallcaps tag">{category}</span>
									</div>
								</div>
							) : null}
						</div>
					</aside>

					<div class="post-content-area">
						<div class="table-header">
							<span class="text-smallcaps">/ Article</span>
						</div>
						
						{heroImage && (
							<div class="article-image-container">
								<img src={heroImage} alt={title} class="article-hero-image" onerror="this.onerror=null; this.src='https://placehold.co/1024x512/111/fff.png?text=Image+Unavailable';" />
								{heroImageAttribution && <div class="attribution" set:html={heroImageAttribution}></div>}
							</div>
						)}
						
						<div class="prose">
							<slot />
						</div>
					</div>
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
